# --- App ---
APP_NAME=Opsora
DEBUG=false
API_PREFIX=/api

# --- Postgres (utilisé par le service db ET par DATABASE_URL) ---
POSTGRES_USER=supervision
POSTGRES_PASSWORD=supervision
POSTGRES_DB=supervision
DATABASE_URL=postgresql+psycopg2://supervision:supervision@db:5432/supervision

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Security (À CHANGER en production) ---
SECRET_KEY=change-me-please-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- Admin seed initial (à changer après premier login) ---
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin1234

# --- SMTP (laisser vide pour désactiver l'email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=supervision@local
SMTP_TLS=true

# --- Scheduler ---
SCHEDULER_INTERVAL_SECONDS=30

# --- IA (Ollama, local) ---
# Depuis Docker, l'hôte est joignable via host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

# --- SSO / OIDC (Enterprise) ---
# Compatible Keycloak, Azure AD/Entra, Google Workspace, Okta, Authentik...
# Redirect URI a declarer chez le fournisseur : https://VOTRE-SERVEUR:8443/api/auth/sso/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SSO_DEFAULT_ROLE=viewer
SSO_AUTO_CREATE_USERS=true

# --- Licence ---
# Vide = edition Community (supervision complete, hotes ILLIMITES).
# Cle Enterprise fournie par l'editeur = active SSO/HA/multi-tenant/support.
LICENSE_KEY=

# --- ITSM / ticketing ---
# provider : internal (défaut, local) | webhook | jira | servicenow
ITSM_PROVIDER=internal
# webhook : URL cible / jira : https://xxx.atlassian.net / servicenow : https://xxx.service-now.com
ITSM_URL=
ITSM_USER=          # e-mail (Jira) ou user (ServiceNow) pour l'auth basic
ITSM_TOKEN=         # API token / clé
ITSM_PROJECT=       # clé de projet Jira (ex. OPS) ou table ServiceNow (défaut: incident)
# Créer un ticket automatiquement à chaque nouvel incident CRITICAL :
ITSM_AUTO_CREATE=false

# --- Ingestion de métriques (agents distants) ---
# Clé attendue dans l'en-tête X-Ingest-Key. ⚠️ Vide = ouvert (dev only).
# EN PRODUCTION : générer une vraie clé et la passer à l'agent (--key).
INGEST_API_KEY=

# --- Sécurité ---
# Origines autorisées (CORS), séparées par des virgules. "*" = tout (dev only).
CORS_ORIGINS=http://localhost:8080
# Anti-bruteforce login : nb d'échecs max par IP sur la fenêtre (secondes).
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300

# --- Rétention des données (purge automatique par le scheduler) ---
RETENTION_CHECK_RESULTS_DAYS=30
RETENTION_HOST_METRICS_DAYS=15
RETENTION_RESOLVED_ALERTS_DAYS=90
RETENTION_PURGE_INTERVAL_MINUTES=60
